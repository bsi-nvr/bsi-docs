{
	"compatibility_date": "2026-05-31",
	"compatibility_flags": ["nodejs_compat"],
	"name": "hudu-docs",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "bsidocs",
			"database_id": "local-db"
		}
	],
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "YOUR_EXISTING_KV_NAMESPACE_ID_HERE"
		}
	],
	"observability": {
		"enabled": true
	}
}